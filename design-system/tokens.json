{
  "$name": "Emma Soft Clay UI",
  "$version": "0.1.0",
  "$description": "Warm-soft-clay design system. Foundation = cooler neutral (V2). Claude 空气感 + Clay 实体感 + 少量高饱和记忆点 + 凹凸并存.",

  "foundation": {
    "appBackground": "#F7F6F2",
    "surface": "#FFFEFC",
    "surfaceWarm": "#FAF6EF",
    "surfaceSunken": "#ECE8E1",
    "surfaceRaised": "#FFFFFF",
    "textPrimary": "#2E2A28",
    "textSecondary": "#6E665F",
    "textTertiary": "#9E9891",
    "borderSoft": "#E8E1D8",
    "borderStrong": "#D8CFC4",
    "divider": "#EEE8E0",
    "globalAccent": "#C7834B"
  },

  "status": {
    "success": { "tint": "#E6F7E9", "main": "#35A853", "ink": "#1E6F36" },
    "warning": { "tint": "#FFF1D0", "main": "#D99612", "ink": "#7A5200" },
    "danger":  { "tint": "#FFE6EA", "main": "#D94B72", "ink": "#8F2443" },
    "info":    { "tint": "#EAF1FF", "main": "#4A88FF", "ink": "#2457B8" }
  },

  "palette": {
    "red":    { "tint": "#FFE8E8", "soft": "#FFC6C6", "main": "#F45B5B", "ink": "#A83232" },
    "rose":   { "tint": "#FFE6EF", "soft": "#FFC1D6", "main": "#F45D8A", "ink": "#A92D56" },
    "orange": { "tint": "#FFEBDD", "soft": "#FFC89F", "main": "#F47B3F", "ink": "#9B431D" },
    "amber":  { "tint": "#FFF1D0", "soft": "#FFD98A", "main": "#F5A914", "ink": "#8A5A00" },
    "yellow": { "tint": "#FFF7CC", "soft": "#FFE985", "main": "#E8C21A", "ink": "#776300" },
    "lime":   { "tint": "#EEF9D6", "soft": "#D4F09A", "main": "#8BCF32", "ink": "#4F7D18" },
    "green":  { "tint": "#E6F7E9", "soft": "#BCECC6", "main": "#35C45A", "ink": "#1F7A3A" },
    "mint":   { "tint": "#E3F7EE", "soft": "#B7EBD3", "main": "#35B985", "ink": "#1E7354" },
    "teal":   { "tint": "#E2F5F2", "soft": "#B3E4DC", "main": "#39B4A6", "ink": "#1F7068" },
    "cyan":   { "tint": "#E3F6FA", "soft": "#B8E8F2", "main": "#36B6D5", "ink": "#1D7185" },
    "blue":   { "tint": "#EAF1FF", "soft": "#C9DCFF", "main": "#4A88FF", "ink": "#2457B8" },
    "indigo": { "tint": "#ECEEFF", "soft": "#CDD3FF", "main": "#6377F2", "ink": "#3745A5" },
    "purple": { "tint": "#F0E8FF", "soft": "#D7C3FF", "main": "#9B6CFF", "ink": "#5E3CB8" },
    "violet": { "tint": "#F5E8FF", "soft": "#E6C5FF", "main": "#B66BEE", "ink": "#743CA0" },
    "brown":  { "tint": "#F5E9DA", "soft": "#E8CBAA", "main": "#C98B52", "ink": "#7A4D28" },
    "gray":   { "tint": "#F0EFEC", "soft": "#DDD9D3", "main": "#8D8780", "ink": "#4D4843" }
  },

  "radius": {
    "tiny": 6,
    "small": 10,
    "medium": 14,
    "large": 18,
    "panel": 24,
    "sheet": 28,
    "pill": 999,
    "usage": {
      "button": 14, "input": 14, "smallCard": 16, "bigCard": 20,
      "bottomSheet": 28, "iconButton": 999
    }
  },

  "shadow": {
    "raisedSoft":   "0 2px 6px rgba(70,66,58,.06), 0 8px 20px rgba(70,66,58,.06)",
    "raisedMedium": "0 4px 10px rgba(70,66,58,.08), 0 14px 28px rgba(70,66,58,.08)",
    "floating":     "0 8px 18px rgba(70,66,58,.10), 0 20px 40px rgba(70,66,58,.10)",
    "sunken":       "inset 2px 2px 5px rgba(70,66,58,.10), inset -2px -2px 5px rgba(255,255,255,.8)"
  },

  "spacing": [4, 8, 12, 16, 20, 24, 32, 48, 64],
  "layout": {
    "pageMarginMobile": 20,
    "pageMarginDesktop": 24,
    "cardGap": 12,
    "sectionGap": 24
  },

  "typography": {
    "fontFamily": "'Noto Sans SC', system-ui, -apple-system, sans-serif",
    "scale": {
      "display":    { "size": 30, "line": 38, "weight": 600 },
      "title":      { "size": 24, "line": 32, "weight": 600 },
      "section":    { "size": 18, "line": 26, "weight": 600 },
      "body":       { "size": 15, "line": 23, "weight": 400 },
      "bodyStrong": { "size": 15, "line": 23, "weight": 600 },
      "caption":    { "size": 13, "line": 18, "weight": 400 },
      "tiny":       { "size": 12, "line": 16, "weight": 400 }
    }
  },

  "icon": {
    "stroke": 2, "cap": "round", "join": "round",
    "sizeSmall": 18, "sizeNormal": 22, "sizeLarge": 26, "button": 44
  },

  "motion": {
    "durations": { "tap": 100, "hover": 140, "cardMove": 180, "sheet": 240, "page": 280 },
    "curve": "cubic-bezier(.2,.8,.2,1)",
    "press": {
      "raised": "translateY(1px), shadow shortened",
      "sunken": "inner shadow deepens",
      "card": "scale(.99) max"
    }
  },

  "ringProgress": {
    "track": "sunken groove (surfaceSunken bg + sunken inset shadow), same as linear track",
    "fill": "Hue Main, round cap, starts at 12 o'clock",
    "under100": "single arc, solid Main",
    "at100": "full ring, solid Main",
    "overfill": {
      "path": "SAME ring path, continue from 12 o'clock over the base ring",
      "noOffset": true, "noThicken": true, "noInnerOuterRings": true,
      "startColor": "exactly Hue Main — zero seam against the full ring",
      "gradient": "linear deepening along the arc from 100% onward, ending at Hue Ink",
      "end": "round cap in Ink — the dark cap marks how far past 100%",
      "svgNote": "gradient coords rotate with the element's transform; pre-rotate the gradient vector to compensate (e.g. rotate(-90) ⇒ vertical becomes x1=133,y1=70,x2=10,y2=70 in a 140 viewBox)"
    }
  }
}
